# Shared config entrypoint: src.config.get_settings()
SIGNALARK_CONFIG_PROFILE=dev
SIGNALARK_CONFIG_FILE=

SIGNALARK_APP_NAME=signalark
SIGNALARK_ENV=dev
SIGNALARK_TIMEZONE=Asia/Shanghai

# Fixed V1 runtime boundary. Do not switch away from these values in Phase 0.
SIGNALARK_EXCHANGE=cn_equity
SIGNALARK_MARKET=a_share
SIGNALARK_EXECUTION_MODE=paper
SIGNALARK_ACCOUNT_ID=paper_account_001
SIGNALARK_PRIMARY_STRATEGY_ID=baseline_momentum_v1
SIGNALARK_SYMBOLS=600036.SH
SIGNALARK_PRIMARY_TIMEFRAME=15m
SIGNALARK_MARKET_DATA_SOURCE=eastmoney

# Required runtime contract for the paper fact source.
SIGNALARK_POSTGRES_DSN=postgresql+psycopg://signalark:signalark@localhost:5432/signalark

# A-share symbol rules and paper cost model live in configs/base.yaml.

# Optional runtime overrides.
SIGNALARK_API_HOST=0.0.0.0
SIGNALARK_API_PORT=8000
SIGNALARK_API_CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:4173,http://localhost:4173
SIGNALARK_LOG_LEVEL=INFO
SIGNALARK_LOG_FORMAT=json
SIGNALARK_LOG_INCLUDE_TRADER_RUN_ID=true
SIGNALARK_LEASE_TTL_SECONDS=15
SIGNALARK_LEASE_HEARTBEAT_INTERVAL_SECONDS=5
SIGNALARK_MARKET_STALE_THRESHOLD_SECONDS=120
SIGNALARK_MAX_SINGLE_SYMBOL_NOTIONAL_CNY=200000
SIGNALARK_MAX_TOTAL_OPEN_NOTIONAL_CNY=500000
SIGNALARK_MIN_ORDER_NOTIONAL_CNY=1000
SIGNALARK_TELEGRAM_ENABLED=false

# Optional secrets. If Telegram is enabled, both values become required.
SIGNALARK_TELEGRAM_BOT_TOKEN=
SIGNALARK_TELEGRAM_CHAT_ID=
